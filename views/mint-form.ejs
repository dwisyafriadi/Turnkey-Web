<!DOCTYPE html>
<html>
  <head>
    <title>Mint Faucet Token</title>
  </head>
  <body>
    <h2>💧 Mint Faucet Token</h2>
    <form action="/mint" method="post">
      <label>Pilih Token:</label><br />
      <select name="token" required>
        <% tokens.forEach(token => { %>
        <option value="<%= token %>"><%= token %></option>
        <% }); %></select
      ><br /><br />

      <label>Amount:</label><br />
      <input type="text" name="amount" required /><br /><br />

      <label>Jumlah Transaksi per Wallet:</label><br />
      <input type="number" name="txCount" required /><br /><br />

      <label>Delay antar transaksi (detik):</label><br />
      <input type="number" name="delay" required /><br /><br />

      <button type="submit">Mulai Mint</button>
    </form>
  </body>
</html>
